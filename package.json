{
  "description": "RSV Companion",
  "name": "rsv-companion",
  "version": "1.1.2",
  "main": "src/main.js",
  "author": "Alejandro Pensado <alex@apensado.com> (http://www.apensado.com/)",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "electron .",
    "build": "npm run dist:win",
    "build-update": "bash ./scripts/build-update.sh",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "sign": "bash ./scripts/sign.sh",
    "dist:all": "electron-builder -mw && npm run sign",
    "dist:mac": "electron-builder --mac && npm run sign",
    "dist:win": "electron-builder --win --x64 && npm run sign",
    "dist:linux": "electron-builder --linux"
  },
  "keywords": [],
  "license": "ISC",
  "dependencies": {
    "auto-launch": "^5.0.6",
    "axios": "^1.7.7",
    "electron-is-dev": "^3.0.1",
    "electron-log": "^5.2.0",
    "electron-updater": "^6.3.4",
    "fs": "*",
    "ini": "^5.0.0",
    "mssql": "^11.0.1",
    "node-os-utils": "^1.3.7",
    "path": "^0.12.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sudo-prompt": "^9.2.1"
  },
  "devDependencies": {
    "electron": "^32.1.2",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.rsvapp.companion",
    "productName": "RSV Companion",
    "artifactName": "${name}-${version}-${os}-${arch}.${ext}",
    "files": [
      "build/**/*",
      "src/**/*"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.utilities"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    },
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": true,
      "deleteAppDataOnUninstall": true
    },
    "directories": {
      "output": "dist/${version}"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "apensadof",
        "repo": "com.rsvapp.companion",
        "private": false
      }
    ]
  }
}
